# ═══════════════════════════════════════════════════════════════
# B&I Universal Intelligence Hub — Environment Configuration
# Version: 5.0  |  Date: April 2026
#
# INSTRUCTIONS:
#   1. Copy this file to .env  (same directory)
#   2. Fill in your credentials below
#   3. That's it — no other config needed
# ═══════════════════════════════════════════════════════════════

# ── Vertex AI (Gemini) ────────────────────────────────────────
# Required for Tier 3 (LLM) queries. Get from GCP Console.
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-pro

# ── Tableau Server ────────────────────────────────────────────
# Required to onboard any dashboard. API version MUST be 3.1.
TABLEAU_SERVER=https://uat.bidata.analytics.global.citigroup.net
TABLEAU_USERNAME=PG23137
TABLEAU_PASSWORD=your-password
TABLEAU_SITE=BI_DATA
TABLEAU_API_VERSION=3.1
TABLEAU_SSL_CERT_PATH=C:\path\to\cacert_sep.pem

# Tableau Timeouts (seconds) — prevents stuck extraction
# Increase these if your server is slow; decrease for faster failure
TABLEAU_AUTH_TIMEOUT=30
TABLEAU_CSV_TIMEOUT=120
TABLEAU_REST_TIMEOUT=60
TABLEAU_IMAGE_TIMEOUT=45

# ── Oracle DB ─────────────────────────────────────────────────
# Optional — app works without it (no audit trail/persistence)
ORACLE_USER=your-oracle-user
ORACLE_PASSWORD=your-oracle-password
ORACLE_DSN=host:1521/service_name
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10

# ── App Settings ──────────────────────────────────────────────
MAX_TOKENS=800
MAX_HISTORY_MESSAGES=20
SNAPSHOT_CACHE_TTL=300
LOG_LEVEL=INFO
